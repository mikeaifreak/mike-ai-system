# =============================================================================
# Mike AI System — Environment Variables Template
# Copy this file to .env and fill in every value.
# NEVER commit .env to git — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Sheets API
# -----------------------------------------------------------------------------
GOOGLE_SHEET_ID=1t0phHXaAJreGY31ro6LLCDQRIyD-KktI-hns-XtIQ
# Absolute path to the JSON key file downloaded from Google Cloud Console.
# The service account must have "Viewer" access to the spreadsheet.
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service-account.json
SHEET_TAB_NAME=Sheet1

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname
# Supabase example: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
POSTGRES_URL=postgresql://user:password@localhost:5432/mike_finance

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
# Bot OAuth token — Settings → OAuth & Permissions in your Slack app
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Channel ID (right-click channel → View channel details → copy the ID at the bottom)
SLACK_CHANNEL_ID=C0123456789

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key
# Override model versions if needed
CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# WhatsApp Business Cloud API (Meta)
# -----------------------------------------------------------------------------
# Permanent access token from Meta Business → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAyour-whatsapp-access-token
# Phone Number ID from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Mike's WhatsApp number in E.164 format without + (e.g. 4917612345678)
WHATSAPP_RECIPIENT_NUMBER=4917600000000
WHATSAPP_API_VERSION=v18.0

# -----------------------------------------------------------------------------
# n8n (used by the automated GitHub backup workflow)
# -----------------------------------------------------------------------------
# Base URL of your n8n instance — no trailing slash
# Cloud: https://your-instance.app.n8n.cloud
# Self-hosted: https://n8n.yourdomain.com or http://localhost:5678
N8N_BASE_URL=https://your-instance.app.n8n.cloud
# API key from n8n → Settings → API → Create API Key
N8N_API_KEY=your-n8n-api-key

# -----------------------------------------------------------------------------
# GitHub (used by the automated backup workflow + shell scripts)
# -----------------------------------------------------------------------------
# Fine-grained PAT with "Contents: Read and Write" on this repo
GITHUB_TOKEN=ghp_your-github-personal-access-token
# Format: owner/repo-name
GITHUB_REPO=your-org/mike-ai-system
# Branch to commit backups to
GITHUB_BRANCH=main

# -----------------------------------------------------------------------------
# Pipeline behaviour
# -----------------------------------------------------------------------------
MODE=morning_report
REPROCESS_WINDOW_DAYS=7
THRESHOLD_ROAS_LOW=1.5
THRESHOLD_REFUND_PCT_HIGH=10.0

# -----------------------------------------------------------------------------
# Dashboard — Mission Control (added for dashboard build)
# -----------------------------------------------------------------------------
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-32-char-secret-here
DASHBOARD_USERNAME=mike
DASHBOARD_PASSWORD=your-dashboard-password

# Docker Compose PostgreSQL service vars (used alongside POSTGRES_URL above)
POSTGRES_DB=mikeai
POSTGRES_USER=mikeai
POSTGRES_PASSWORD=your-postgres-password
