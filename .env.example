# =============================================================================
# Mike AI System — Environment Variables Template
# Copy this file to .env and fill in every value.
# NEVER commit .env to git — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Sheets (via Google Apps Script web app)
# Deploy the script as a web app with "Anyone" access, then paste the URL.
#
# Single store (current default):
#   GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
#   → stored as store_id='default' in daily_pl
#
# Multi-store (future — when Mike has multiple Shopify stores):
#   GOOGLE_SCRIPT_URL={"store_nl":"https://script.google.com/macros/s/ID1/exec","store_de":"https://script.google.com/macros/s/ID2/exec"}
#   → each store_id gets its own rows; same date can exist once per store
#   → activate by iterating config.GOOGLE_STORE_URLS.items() in main.py
# -----------------------------------------------------------------------------
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=mikeai
POSTGRES_USER=mikeai
POSTGRES_PASSWORD=your-strong-password
# Format: postgresql://user:password@host:port/dbname
# Inside Docker use hostname "postgres" (the service name), not localhost.
POSTGRES_URL=postgresql://mikeai:your-strong-password@postgres:5432/mikeai

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
# Bot OAuth token — Slack app → OAuth & Permissions (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Primary / legacy key (set to same value as SLACK_REPORTS_CHANNEL)
SLACK_CHANNEL_ID=C0123456789
# Channel IDs — right-click channel in Slack → View channel details → bottom of panel
SLACK_REPORTS_CHANNEL=C0123456789
SLACK_ALERTS_CHANNEL=C0123456789
SLACK_INVOICES_CHANNEL=C0123456789

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-proj-your-openai-api-key
CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# WhatsApp Business Cloud API (Meta)
# -----------------------------------------------------------------------------
# Permanent access token from Meta Business → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAyour-whatsapp-access-token
# Phone Number ID from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Mike's WhatsApp number in E.164 format without + (e.g. 31612345678 for NL)
WHATSAPP_RECIPIENT_NUMBER=31600000000
WHATSAPP_API_VERSION=v18.0

# -----------------------------------------------------------------------------
# Google Ads spend sheets (Apps Script web app URLs — runs daily at 06:45)
#
# HOW IT WORKS:
# 1. Mike opens each Google Ads account
# 2. Tools & Settings → Bulk Actions → Scripts → paste google-ads-script.js
# 3. The script runs daily, writing campaign spend rows to a Google Sheet
# 4. Deploy an Apps Script web app on that sheet (same as GOOGLE_SCRIPT_URL)
# 5. Paste the web app URL(s) here
#
# Single store:  GOOGLE_ADS_SHEET_URLS=https://script.google.com/macros/s/ID/exec
# Multi-store:   GOOGLE_ADS_SHEET_URLS=store_nl:https://...ID1.../exec,store_de:https://...ID2.../exec
# JSON map:      GOOGLE_ADS_SHEET_URLS={"store_nl":"https://...","store_de":"https://..."}
# -----------------------------------------------------------------------------
GOOGLE_ADS_SHEET_URLS=

# -----------------------------------------------------------------------------
# Shopify Admin REST API
# Create a Custom App: Shopify Admin → Settings → Apps → Develop apps
# Scopes needed: read_orders
# -----------------------------------------------------------------------------
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret
SHOPIFY_API_TOKEN=shpat_your-admin-api-token

# -----------------------------------------------------------------------------
# Pinterest Ads spend sheets (Apps Script web app URLs — runs daily at 06:46)
#
# HOW IT WORKS: same pattern as Google Ads above.
# 1. Install scripts/pinterest-ads-script.js in each Pinterest Ads account
# 2. Script runs daily, writing campaign spend to a Google Sheet
# 3. Deploy an Apps Script web app on that sheet
# 4. Paste the URL(s) here
#
# Single store:  PINTEREST_ADS_SHEET_URLS=https://script.google.com/macros/s/ID/exec
# Multi-store:   PINTEREST_ADS_SHEET_URLS=store_nl:https://...ID1.../exec,store_de:https://...ID2.../exec
# -----------------------------------------------------------------------------
PINTEREST_ADS_SHEET_URLS=

# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------
# Any IANA timezone name — sets the clock for all cron jobs
SCHEDULER_TIMEZONE=Europe/Amsterdam

# -----------------------------------------------------------------------------
# Pipeline behaviour
# -----------------------------------------------------------------------------
REPROCESS_WINDOW_DAYS=7
THRESHOLD_ROAS_LOW=1.5
THRESHOLD_REFUND_PCT_HIGH=10.0

# -----------------------------------------------------------------------------
# Dashboard — Mission Control
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET=your-32-char-hex-secret
DASHBOARD_USERNAME=mike
DASHBOARD_PASSWORD=your-dashboard-password
