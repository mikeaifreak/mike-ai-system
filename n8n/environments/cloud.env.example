# =============================================================================
# n8n CLOUD Environment — variable overrides
# These are set in n8n Cloud → Settings → Variables (not in .env)
# Reference in workflows as: {{ $env.VARIABLE_NAME }}
# =============================================================================

# n8n Cloud instance URL — no trailing slash
N8N_BASE_URL=https://your-instance.app.n8n.cloud

# n8n API key for the backup workflow
N8N_API_KEY=your-n8n-cloud-api-key

# Python scripts run via Execute Command — path inside n8n Cloud worker
# n8n Cloud runs workflows in a sandboxed environment.
# If Execute Command is restricted on your plan, use the n8n HTTP Request
# node to call a dedicated FastAPI endpoint running on an external server.
APP_ROOT=/home/node/app

# All other variables (Google, Slack, WhatsApp, etc.) are identical
# to the root .env.example — configure them in n8n Cloud Variables UI.
