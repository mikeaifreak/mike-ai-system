# =============================================================================
# n8n SELF-HOSTED (Mac Mini) Environment
# Place this file at ~/.n8n/.env or pass via --env-file to Docker.
# =============================================================================

# n8n instance URL (update after setting up reverse proxy / domain)
N8N_BASE_URL=http://localhost:5678
# Or with your domain: N8N_BASE_URL=https://n8n.yourdomain.com

# Generate via n8n UI → Settings → API → Create API Key
N8N_API_KEY=your-self-hosted-api-key

# Timezone (cron schedules use this)
GENERIC_TIMEZONE=Europe/Berlin

# Encryption key — generate once and keep safe (required for stored credentials)
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=generate-a-32-byte-hex-key

# Basic auth for n8n UI (remove in production behind SSO/VPN)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Data location
N8N_USER_FOLDER=/Users/mike/.n8n

# Webhook URL (set if running behind a reverse proxy)
# WEBHOOK_URL=https://n8n.yourdomain.com/

# Python path (set if not in system PATH)
# PYTHON_PATH=/usr/local/bin/python3

# App root — where the mike-ai-system repo is cloned on Mac Mini
APP_ROOT=/Users/mike/mike-ai-system

# All other variables (Google, Postgres, Slack, WhatsApp, AI keys, GitHub)
# are identical to root .env.example — copy and fill them here as well.
